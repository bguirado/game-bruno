programa {
  funcao inicio() {
    caracter n
    escreva ("Digite o número: ")
    leia (n)
    escolha (n) {
  caso '1':
   escreva("Fogo")
   pare
  caso '2':
   escreva("Água")
   pare
  caso '3':
   escreva("Terra")
   pare
  caso '4':
   escreva("Ar")
   pare
  caso contrario:
   escreva("Armadilha!")
  }
 }
}