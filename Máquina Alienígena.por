programa {
  funcao inicio() {
    caracter botao
    escreva ("Digite a letra: ")
    leia (botao)
    escolha (botao) {
  caso 'Z':
   escreva("Zíngaro")
   pare
  caso 'X':
   escreva("Xarope")
   pare
  caso 'K':
   escreva("Kriptonita")
   pare
  caso contrario:
   escreva("Letra não reconhecida!")
  }
 }
}